<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vídeos</title>
</head>
<body>

    <h1>Lista de Vídeos</h1>

    {{#each videos}}
        <div>
            <h3>{{titulo}}</h3>
            <p>{{descricao}}</p>
        </div>
        <hr>
        <a href="/videos/editar/{{id}}">
    <button type="button">Editar</button>
    </a>
    <form action="/videos/deletar/{{id}}" method="POST" style="display:inline;">
    <button type="submit">Excluir</button>
    </form>
    {{/each}}

</body>
</html>
