<h1>Cadastrar Usuário</h1>

<form action="/usuarios" method="POST">

    <div>
        <label>Nome:</label>
        <input type="text" name="nome">
    </div>

    <br>

    <div>
        <label>Email:</label>
        <input type="email" name="email">
    </div>

    <br>

    <div>
        <label>Idade:</label>
        <input type="number" name="idade">
    </div>

    <br>

    <button type="submit">
        Cadastrar
    </button>

</form>